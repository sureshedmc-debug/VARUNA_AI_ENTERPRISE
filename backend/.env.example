# VARUNA AI Enterprise – Environment Configuration Example
# Copy this file to .env and adjust values for your setup.

# ──────────────────────────────────────────────────────────────
# MAVLink / Pixhawk 2.4.8 connection
# Serial on Raspberry Pi 3A+:  /dev/serial0  (GPIO UART) or /dev/ttyUSB0
# UDP simulation:               udpin:0.0.0.0:14550
# ──────────────────────────────────────────────────────────────
VARUNA_MAVLINK_CONNECTION=/dev/serial0
VARUNA_MAVLINK_BAUD=57600
VARUNA_MAVLINK_SOURCE_SYSTEM=255
VARUNA_MAVLINK_SOURCE_COMPONENT=0
VARUNA_MAVLINK_TIMEOUT=5.0
VARUNA_MAVLINK_HEARTBEAT_INTERVAL=1.0
VARUNA_MAVLINK_RECONNECT_DELAY=2.0
VARUNA_MAVLINK_MAX_RECONNECT_DELAY=30.0

# ──────────────────────────────────────────────────────────────
# API server
# ──────────────────────────────────────────────────────────────
VARUNA_HOST=0.0.0.0
VARUNA_PORT=8000
VARUNA_DEBUG=false

# ──────────────────────────────────────────────────────────────
# WebSocket telemetry streaming (seconds between frames)
# 0.1 = 10 Hz
# ──────────────────────────────────────────────────────────────
VARUNA_WS_TELEMETRY_INTERVAL=0.1

# ──────────────────────────────────────────────────────────────
# Timeouts (seconds)
# ──────────────────────────────────────────────────────────────
VARUNA_PARAM_FETCH_TIMEOUT=30.0
VARUNA_MISSION_TIMEOUT=30.0
VARUNA_COMMAND_ACK_TIMEOUT=5.0
